{
  "name": "persevex-resume-maker",
  "version": "1.0.0",
  "description": "The world's most sophisticated resume engineering platform",
  "private": true,
  "engines": {
    "node": "22.12.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install-all": "npm install --workspaces",
    "dev": "npm run dev --workspaces",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start",
    "build:frontend": "npm --prefix client run build",
    "start:frontend": "npm --prefix client run dev",
    "start:backend": "npm --prefix server run dev"
  },
  "keywords": [
    "resume",
    "builder",
    "templates",
    "ATS",
    "career"
  ],
  "author": "Persevex",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/persevex-resume-maker"
  }
}
